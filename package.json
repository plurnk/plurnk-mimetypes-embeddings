{
    "name": "@plurnk/plurnk-mimetypes-embeddings",
    "version": "0.8.1",
    "description": "Opt-in embedder for @plurnk/plurnk-mimetypes' embedding channel. Bundles Xenova/all-MiniLM-L6-v2 (q8 onnx, 384-d) on a vendored portable WASM runtime (onnxruntime-web) — hermetic, no native addon, no runtime network, no transitive install scripts.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=26"
    },
    "exports": {
        ".": {
            "default": "./index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "index.js",
        "embed-core.js",
        "embed-worker.js",
        "model/**",
        ".model-pin",
        "vendor/**",
        ".ort-pin",
        "README.md"
    ],
    "scripts": {
        "build:model": "node scripts/fetch-model.mjs",
        "verify:model": "node scripts/verify-model.mjs",
        "vendor:ort": "node scripts/vendor-ort.mjs",
        "verify:ort": "node scripts/verify-ort.mjs",
        "pretest": "npm run verify:ort",
        "test:unit": "PLURNK_EMBED_WORKERS=2 node --test index.test.js",
        "test:integration": "PLURNK_EMBED_WORKERS=2 node --test test/integration/*.test.js",
        "test": "npm run test:unit && npm run test:integration",
        "deps:fresh": "npm outdated",
        "prepublishOnly": "npm run deps:fresh && npm audit --audit-level=moderate && npm test",
        "prepare": "(git config core.hooksPath .githooks || true)"
    },
    "dependencies": {
        "@huggingface/tokenizers": "^0.1.3"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.16.0"
    }
}
